# Firebase Database Configuration
# The Realtime Database URL (e.g. https://capstone-prototype-7b1f9.firebaseio.com)
FIREBASE_DATABASE_URL=https://capstone-prototype-7b1f9.firebaseio.com/

# Path to the Google Application Credentials JSON file for Firebase Admin SDK
# Optional if using other authentication methods, but highly recommended for local python admin scripts.
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
